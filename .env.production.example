# ══════════════════════════════════════════════════════════════
# Switch OS — Variables de Entorno de Producción
# Copia este archivo como referencia para configurar Vercel.
# ⚠️  NUNCA commitear el .env real con valores reales.
# ══════════════════════════════════════════════════════════════

# ─── BASE DE DATOS (Supabase) ──────────────────────────────────
# pgBouncer pooling — para queries normales de la app
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Conexión directa — solo para prisma migrate deploy en CI
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── AUTENTICACIÓN (Supabase) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ─── EMAIL (SMTP / nodemailer) ─────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="noreply@switchos.mx"
SMTP_PASS="[google-app-password-16-chars]"
SMTP_FROM="Switch OS <noreply@switchos.mx>"

# ─── STRIPE ────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Price IDs (crear en stripe.com Dashboard → Products)
# Price IDs por plan y ciclo (crear en stripe.com → Products)
STRIPE_PRICE_STARTER_MONTHLY="price_..."
STRIPE_PRICE_STARTER_ANNUAL="price_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_ANNUAL="price_..."
STRIPE_PRICE_ENTERPRISE_MONTHLY="price_..."
STRIPE_PRICE_ENTERPRISE_ANNUAL="price_..."

# ─── APLICACIÓN ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://app.switchos.mx"
NODE_ENV="production"

# ─── CSD VAULT (encriptación AES-256) ─────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSD_ENCRYPTION_KEY="[64-char-hex-string]"

# ─── VERCEL (para GitHub Actions CI/CD) ───────────────────────
# Obtener desde: vercel.com → Account Settings → Tokens
VERCEL_TOKEN="[vercel-token]"
# Obtener corriendo: vercel link (crea .vercel/project.json)
VERCEL_ORG_ID="[org-id]"
VERCEL_PROJECT_ID="[project-id]"
