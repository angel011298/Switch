generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  OPERATIVE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

enum PaymentProofStatus {
  PENDING   // Comprobante subido, esperando revision
  APPROVED  // Super Admin aprobo, +30 dias sumados
  REJECTED  // Super Admin rechazo, con motivo
}

enum ModuleKey {
  // Centro Estrategico
  DASHBOARD
  CALENDAR
  BI

  // Capital Humano (HCM)
  HCM
  PAYROLL
  TALENT
  EMPLOYEE_PORTAL  // Portal de autoservicio del empleado

  // Finanzas (ERP Core)
  FINANCE
  TAXES
  COLLECTIONS
  BANKING          // Open Banking / Conciliación bancaria automática
  CASH_FLOW        // Flujo de Efectivo y Tesorería predictiva

  // SAT & Compliance
  SAT_TOOLS        // Buzón tributario + 69-B + DIOT automática
  REPSE            // Módulo REPSE y subcontratación
  NOM035           // NOM-035 Riesgos Psicosociales

  // Facturacion Electronica SAT
  BILLING_CFDI
  CARTA_PORTE      // Complemento Carta Porte 3.0 + factura masiva

  // Punto de Venta
  POS

  // Comercial (CRM & CX)
  CRM
  MARKETING
  SUPPORT

  // Operaciones (SCM)
  SCM
  INVENTORY
  LOGISTICS

  // Manufactura (MRP)
  MRP
  QUALITY

  // Servicios y Proyectos
  PROJECTS
}

// Tipo de persona para efectos fiscales (Art. 1 CFF)
enum PersonType {
  FISICA
  MORAL
}

// Tipo de impuesto segun legislacion mexicana
enum TaxType {
  IVA           // Impuesto al Valor Agregado (LIVA)
  ISR           // Impuesto Sobre la Renta (LISR)
  IEPS          // Impuesto Especial sobre Produccion y Servicios
  ISH           // Impuesto Sobre Hospedaje (estatal)
  RETENCION_IVA // Retencion de IVA (Art. 1-A LIVA)
  RETENCION_ISR // Retencion de ISR (Art. 106 LISR)
}

// Tipo de operacion para determinar reglas aplicables
enum OperationType {
  SALE_PRODUCT        // Venta de bienes
  SALE_SERVICE        // Prestacion de servicios
  PURCHASE_PRODUCT    // Compra de bienes
  PURCHASE_SERVICE    // Adquisicion de servicios
  PAYROLL             // Nomina
  LEASE               // Arrendamiento
  ROYALTY             // Regalias
  COMMISSION          // Comisiones
}

// Estado del CFDI en el ciclo de vida de facturacion
enum InvoiceStatus {
  DRAFT       // Borrador, aun no sellado
  SEALED      // Sellado con CSD, listo para timbrar
  STAMPED     // Timbrado por PAC (UUID asignado)
  CANCELLED   // Cancelado ante el SAT
  ERROR       // Error en timbrado o cancelacion
}

// Tipo de comprobante (c_TipoDeComprobante Anexo 20)
enum TipoComprobante {
  I   // Ingreso
  E   // Egreso
  T   // Traslado
  P   // Pago
  N   // Nomina
}

// Metodo de pago (c_MetodoPago)
enum MetodoPago {
  PUE  // Pago en Una sola Exhibicion
  PPD  // Pago en Parcialidades o Diferido
}

// ─── MODELOS CORE ───────────────────────────────────────

model Tenant {
  id               String         @id @default(uuid())
  name             String
  rfc              String?
  personType       PersonType?
  stripeCustomerId String?        @unique

  // Perfil fiscal del Tenant (CFDI 4.0)
  taxRegimeId      String?
  taxRegime        TaxRegime?     @relation(fields: [taxRegimeId], references: [id])
  zipCode          String?        // Codigo postal del domicilio fiscal (requerido CFDI 4.0)
  legalName        String?        // Razon social / Nombre completo para facturacion
  csdCerUploaded   Boolean        @default(false)
  csdKeyUploaded   Boolean        @default(false)
  logoUrl          String?

  // FASE 12: Onboarding
  onboardingComplete Boolean      @default(false) // true = RFC/nombre/CP capturados

  // FASE 51: Seguridad — timeout de sesión en minutos (default 8h)
  sessionTimeoutMinutes Int        @default(480)

  // FASE 48: Nómina CFDI — registro patronal IMSS
  registroPatronal  String?

  // FASE 52: Geofence de trabajo (Reloj Checador)
  workLat               Float?   // Latitud de la ubicación de trabajo
  workLon               Float?   // Longitud de la ubicación de trabajo
  workAddress           String?  // Descripción de la ubicación (ej. "Av. Insurgentes 1234")
  radioToleranceMeters  Int      @default(100)  // Radio de geocerca en metros

  // Aceptación de términos legales
  termsAcceptedAt  DateTime?  // Fecha en que el usuario aceptó T&C, Privacidad y Cookies

  subscription     Subscription?
  paymentProofs    PaymentProof[]
  modules          TenantModule[]
  memberships      TenantMembership[]
  projects         Project[]
  invoices         Invoice[]
  csdVault         CsdVault?
  customers        Customer[]
  products         Product[]
  posOrders        PosOrder[]
  accounts         Account[]
  journalEntries   JournalEntry[]
  xmlBatches       XmlBatch[]
  employees        Employee[]     // FASE 12: Capital humano
  payrollRuns      PayrollRun[]   // FASE 15: Nómina
  pettyCashFunds   PettyCashFund[] // FASE 16: Caja chica
  warehouses       Warehouse[]     // FASE 17: SCM almacenes
  pipelineColumns  PipelineColumn[] // FASE 18: CRM Pipeline
  deals            Deal[]           // FASE 18: CRM Deals
  webhookEndpoints WebhookEndpoint[] // FASE 37: Integraciones
  apiKeys          ApiKey[]          // FASE 37: API pública
  workShifts       WorkShift[]       // FASE 52: Turnos
  cashCuts         CashCut[]         // FASE 52: Corte de Caja POS
  bankAccounts     BankAccount[]     // FASE 52: Tesorería
  treasuryTx       TreasuryTransaction[] // FASE 52: Movimientos bancarios
  cfdiRecibidos    CfdiRecibido[]    // FASE 52: Mis CFDI recibidos
  contractSignature ContractSignature? // Firma digital del contrato

  // Nuevos módulos
  bankConnections  BankConnection[]   // Open Banking
  satCredential    SatCredential?     // Buzón tributario SAT
  satDownloads     SatCfdiDownload[]  // XMLs descargados del SAT
  complianceAlerts ComplianceAlert[]  // Alertas fiscales
  repseRegistration RepseRegistration? // Registro REPSE
  repseContracts   RepseContract[]    // Contratos REPSE
  nom035Surveys    Nom035Survey[]     // Encuestas NOM-035
  cashFlowProjections CashFlowProjection[] // Flujo de efectivo
  diotRecords      DiotRecord[]       // Declaraciones DIOT
  cartaPortes      CartaPorte[]       // Cartas Porte

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model TenantModule {
  id          String    @id @default(uuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  moduleKey   ModuleKey
  isActive    Boolean   @default(true)
  activatedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tenantId, moduleKey])
  @@index([tenantId, isActive])
}

model Subscription {
  id        String             @id @default(uuid())
  tenantId  String             @unique
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId    String             @default("standard")
  status    SubscriptionStatus @default(TRIAL)
  validUntil DateTime?         // Fecha de vencimiento de la suscripcion activa
  trialEnds  DateTime?         // Fecha de fin del periodo de prueba

  // ── Stripe (FASE 22) ───────────────────────────────────────────────────────
  stripeSubscriptionId  String?   @unique  // sub_xxxxxx
  stripePriceId         String?            // price_xxxxxx (plan activo)
  stripeCurrentPeriodEnd DateTime?          // Fin del periodo de facturación activo

  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

// Comprobante de pago SPEI subido por el Tenant
model PaymentProof {
  id            String             @id @default(uuid())
  tenantId      String
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Datos del pago declarados por el Tenant
  amount        Decimal            @db.Decimal(10, 2)   // Monto transferido
  transferRef   String?            // Clave de rastreo SPEI (opcional)
  concept       String?            // Concepto de la transferencia
  paidAt        DateTime           // Fecha en que realizaron el pago

  // Archivo comprobante (almacenado como base64 en DB o URL si se usa Storage)
  fileName      String
  fileType      String             // "application/pdf" | "image/jpeg" | "image/png"
  fileBase64    String             @db.Text   // Base64 del archivo (max ~2MB)

  // Control de revision por Super Admin
  status        PaymentProofStatus @default(PENDING)
  reviewedBy    String?            // Email del Super Admin que reviso
  reviewedAt    DateTime?
  rejectionNote String?            // Motivo de rechazo (si aplica)

  // Resultado de la aprobacion
  daysGranted   Int?               // Dias sumados al validUntil al aprobar
  newValidUntil DateTime?          // Nuevo validUntil calculado al aprobar

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([tenantId, status])
  @@index([status, createdAt])
}

model User {
  id               String      @id
  email            String      @unique
  name             String?
  avatarUrl        String?
  timezone         String      @default("America/Mexico_City")

  memberships      TenantMembership[]

  // Campos de registro
  personType       String?
  rfc              String?
  phone            String?
  age              Int?
  gender           String?
  isSuperAdmin     Boolean     @default(false)

  fullyLoadedCost  Decimal     @default(0.0) @db.Decimal(10, 2)
  timeEntries      TimeEntry[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // FASE 51: Seguridad 2FA
  twoFactorEnabled  Boolean  @default(false)
  twoFactorSecret   String?  // TOTP secret (encrypted via app-level AES, stored as base64)
}

model TenantMembership {
  id        String  @id @default(uuid())
  userId    String
  tenantId  String
  role      Role    @default(OPERATIVE)
  
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
}

model Project {
  id                String      @id @default(uuid())
  tenantId          String
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name              String
  contractValue     Decimal     @default(0.0) @db.Decimal(12, 2)
  pocPercentage     Decimal     @default(0.0) @db.Decimal(5, 2)
  tasks             Task[]
  timeEntries       TimeEntry[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([tenantId])
}

model Task {
  id          String      @id @default(uuid())
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  isCompleted Boolean     @default(false)
  timeEntries TimeEntry[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model TimeEntry {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  hours       Decimal  @db.Decimal(5, 2)
  date        DateTime @default(now())
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
}

// ─── PUNTO DE VENTA (POS) ───────────────────────────────

/// Producto o servicio del catalogo del Tenant.
/// Se cachea en el cliente (Zustand) para operacion offline-first.
model Product {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  sku             String?           // Codigo interno del producto
  barcode         String?           // Codigo de barras (EAN/UPC)
  name            String
  description     String?
  category        String?           // Categoria libre para filtrado rapido
  claveProdServ   String            // Clave SAT c_ClaveProdServ
  claveUnidad     String  @default("H87") // c_ClaveUnidad (H87 = Pieza)
  unidad          String? @default("Pieza")

  price           Decimal @db.Decimal(12, 2) // Precio de venta (puede ser con o sin IVA)
  priceIncludesTax Boolean @default(true)    // true = precio ya incluye IVA (comun en retail)
  taxRate         Decimal @default(0.16) @db.Decimal(8, 6) // Tasa de impuesto (0.16 = 16%)
  cost            Decimal? @db.Decimal(12, 2) // Costo (para margen)

  stock           Int     @default(0)        // Inventario disponible
  minStock        Int     @default(0)        // Mínimo para alerta de reorden
  trackStock      Boolean @default(false)    // true = descontar stock en venta

  imageUrl        String?
  isActive        Boolean @default(true)

  orderItems      PosOrderItem[]
  stockMovements  StockMovement[]  // FASE 17
  boms           BOM[]              // FASE 33: MRP (producto terminado)
  bomComponents  BOMItem[]          @relation("BOMComponent")  // FASE 33: componente en BOM
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, sku])
  @@index([tenantId, isActive])
  @@index([tenantId, barcode])
}

/// Orden/Ticket del Punto de Venta.
/// Cada venta genera un ticket con codigo unico para auto-facturacion.
model PosOrder {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Codigo alfanumerico unico para auto-factura (ej. "SW-A3K9M2")
  ticketCode      String   @unique
  orderNumber     Int      // Consecutivo por tenant

  // Totales (desglose inverso si precio incluye IVA)
  subtotal        Decimal  @db.Decimal(12, 2)
  totalTax        Decimal  @db.Decimal(12, 2)
  discount        Decimal  @default(0) @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)

  // Pago
  paymentMethod   String   @default("01") // c_FormaPago SAT (01=Efectivo, 04=Tarjeta)
  amountPaid      Decimal  @db.Decimal(12, 2)
  changeDue       Decimal  @default(0) @db.Decimal(12, 2) // Cambio

  // Estado de facturacion
  isInvoiced      Boolean  @default(false) // true = ya se genero CFDI
  invoiceId       String?  // ID de la Invoice si fue facturado

  // Datos del cajero
  cashierId       String?  // userId del cajero

  items           PosOrderItem[]
  closedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, closedAt])
  @@index([tenantId, ticketCode])
  @@index([tenantId, isInvoiced])
}

/// Linea de un ticket POS.
model PosOrderItem {
  id              String   @id @default(uuid())
  orderId         String
  order           PosOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId       String
  product         Product  @relation(fields: [productId], references: [id])

  productName     String   // Snapshot del nombre al momento de la venta
  quantity        Decimal  @db.Decimal(10, 3) // Soporta fracciones (ej. 1.5 kg)
  unitPrice       Decimal  @db.Decimal(12, 2) // Precio unitario SIN IVA
  taxRate         Decimal  @db.Decimal(8, 6)  // Tasa aplicada
  taxAmount       Decimal  @db.Decimal(12, 2) // Impuesto de esta linea
  subtotal        Decimal  @db.Decimal(12, 2) // quantity * unitPrice
  total           Decimal  @db.Decimal(12, 2) // subtotal + taxAmount
  discount        Decimal  @default(0) @db.Decimal(12, 2)

  createdAt       DateTime @default(now())

  @@index([orderId])
}

// ─── CRM: CLIENTES / TERCEROS FISCALES ─────────────────

/// Cliente/Tercero fiscal del Tenant.
/// Almacena datos fiscales validados del receptor para facturación CFDI 4.0.
/// Los datos pueden ingresarse manualmente o via escaneo QR de la CSF del SAT.
///
/// Validaciones:
/// - RFC: 12 chars (Persona Moral) o 13 chars (Persona Física) — regex SAT oficial
/// - Código postal: 5 dígitos
/// - Régimen fiscal: vinculado al catálogo TaxRegime
///
/// Ref: CFF Art. 27 (inscripción RFC), Anexo 20 nodo cfdi:Receptor
model Customer {
  id                String      @id @default(uuid())
  tenantId          String
  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // ID público / comercial (amigable para capturistas)
  displayCode       String?     // Ej: "CLI-0001" — único por tenant (null en registros anteriores a esta feature)

  // Datos fiscales (requeridos para CFDI 4.0)
  rfc               String      // RFC validado (12 o 13 caracteres)
  legalName         String      // Razón social o nombre completo
  personType        PersonType  // FISICA o MORAL
  zipCode           String      // Código postal del domicilio fiscal
  email             String?     // Email de contacto

  // Régimen fiscal del cliente (catálogo SAT)
  taxRegimeId       String?
  taxRegime         TaxRegime?  @relation(fields: [taxRegimeId], references: [id])

  // Uso de CFDI preferido (c_UsoCFDI)
  defaultUsoCfdi    String?     // Ej: "G03" = Gastos en general

  // Datos comerciales CRM
  phone             String?
  address           String?
  city              String?
  state             String?
  notes             String?
  tags              String?     // Tags separados por coma para segmentación

  // Origen del registro
  source            String      @default("MANUAL") // MANUAL, QR_SCAN, CSV_IMPORT, API

  isActive          Boolean     @default(true)
  deals             Deal[]      // FASE 18: CRM pipeline
  portalTokens      CustomerPortalToken[]  // FASE 27: Portal público
  supportTickets    SupportTicket[]        // FASE 32: Soporte
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([tenantId, rfc])         // Un RFC por Tenant (evita duplicados)
  @@unique([tenantId, displayCode]) // Un código público por Tenant (NULL no conflicta en PG)
  @@index([tenantId, isActive])
  @@index([tenantId, rfc])
}

// ─── MOTOR DE REGLAS FISCALES (SAT) ────────────────────

/// Catalogo de regimenes fiscales del SAT (c_RegimenFiscal).
/// Ref: Anexo 20 CFDI 4.0 — Catalogo c_RegimenFiscal.
/// Cada registro corresponde a una clave del catalogo oficial.
model TaxRegime {
  id           String     @id @default(uuid())
  satCode      String     @unique // Clave SAT ej. "601", "612", "626"
  name         String     // Nombre oficial: "General de Ley Personas Morales"
  personType   PersonType // A que tipo de persona aplica
  isActive     Boolean    @default(true)
  tenants      Tenant[]
  customers    Customer[]
  rules        TaxRuleRegime[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([personType, isActive])
}

/// Regla de impuesto parametrizada. Cada regla define UNA tasa o cuota
/// para UN tipo de impuesto, aplicable a ciertos regimenes y operaciones.
///
/// Ejemplo: "IVA 16% trasladado en venta de productos, vigente desde 2024-01-01"
///
/// El campo validTo = null significa regla vigente indefinidamente.
/// Cuando la Miscelanea Fiscal cambia, se crea una nueva regla con validFrom
/// actualizado y se cierra la anterior con validTo.
///
/// Ref: LIVA Art. 1, 2-A | LISR Art. 106, 111, 113 | RMF vigente
model TaxRule {
  id              String        @id @default(uuid())
  code            String        @unique // Identificador interno: "IVA_GENERAL_16", "RET_ISR_RESICO_125"
  name            String        // Nombre descriptivo legible
  description     String?       // Fundamento legal detallado

  taxType         TaxType       // IVA, ISR, IEPS, RETENCION_IVA, RETENCION_ISR
  operationType   OperationType // Tipo de operacion donde aplica
  rate            Decimal       @db.Decimal(8, 6) // Tasa: 0.160000 = 16%, 0.012500 = 1.25%
  isPercentage    Boolean       @default(true)     // true = porcentaje, false = cuota fija
  isWithholding   Boolean       @default(false)    // true = retencion (se resta del total)

  // Condiciones de aplicacion automatica
  // Si ambos son null, aplica a cualquier combinacion emisor/receptor
  emitterPersonType  PersonType?  // Tipo de persona del EMISOR (quien factura)
  receiverPersonType PersonType?  // Tipo de persona del RECEPTOR (quien recibe)

  // Vigencia temporal (soporta versionado de Miscelanea Fiscal)
  validFrom       DateTime       // Inicio de vigencia
  validTo         DateTime?      // Fin de vigencia (null = vigente)

  // Relacion M:N con regimenes
  regimes         TaxRuleRegime[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([taxType, operationType])
  @@index([validFrom, validTo])
}

/// Tabla pivote: que reglas aplican a que regimenes.
/// Permite que una regla aplique a multiples regimenes y viceversa.
model TaxRuleRegime {
  id          String    @id @default(uuid())
  taxRuleId   String
  taxRule     TaxRule   @relation(fields: [taxRuleId], references: [id], onDelete: Cascade)
  taxRegimeId String
  taxRegime   TaxRegime @relation(fields: [taxRegimeId], references: [id], onDelete: Cascade)

  @@unique([taxRuleId, taxRegimeId])
  @@index([taxRegimeId])
}

// ─── MOTOR DE FACTURACION CFDI 4.0 ─────────────────────

/// Boveda de CSD (Certificado de Sello Digital) por Tenant.
/// Almacena .cer, .key (bytes) y contrasena cifrada con AES-256-GCM.
/// Ref: CFF Art. 17-D, 29 fraccion II.
model CsdVault {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  cerDer         Bytes    // Archivo .cer en formato DER (binario)
  keyDer         Bytes    // Archivo .key en formato DER cifrado por SAT

  // Contrasena del .key cifrada con AES-256-GCM
  passwordEnc    String   // Ciphertext base64
  passwordIv     String   // IV base64 (12 bytes)
  passwordTag    String   // Auth tag base64 (16 bytes)

  // Datos extraidos del certificado
  noCertificado  String   // Numero de certificado (20 digitos)
  validFrom      DateTime // Inicio de vigencia del CSD
  validTo        DateTime // Fin de vigencia del CSD
  isActive       Boolean  @default(true)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

/// Factura electronica CFDI 4.0.
/// Ref: CFF Art. 29, 29-A | Anexo 20 SAT.
model Invoice {
  id                 String          @id @default(uuid())
  tenantId           String
  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status             InvoiceStatus   @default(DRAFT)

  // Identificadores
  serie              String?
  folio              Int
  uuid               String?         @unique // UUID del Timbre Fiscal Digital

  // Datos del comprobante
  fechaEmision       DateTime        @default(now())
  tipoComprobante    TipoComprobante @default(I)
  formaPago          String          // Clave SAT c_FormaPago (ej. "01", "03", "99")
  metodoPago         MetodoPago      @default(PUE)
  moneda             String          @default("MXN")
  tipoCambio         Decimal?        @db.Decimal(10, 4)
  lugarExpedicion    String          // Codigo postal del lugar de expedicion
  exportacion        String          @default("01") // c_Exportacion
  condicionesDePago  String?

  // Emisor
  emisorRfc             String
  emisorNombre          String
  emisorRegimenFiscal   String       // Clave SAT c_RegimenFiscal

  // Receptor
  receptorRfc              String
  receptorNombre           String
  receptorDomicilioFiscal  String    // CP del receptor
  receptorRegimenFiscal    String    // Clave SAT c_RegimenFiscal del receptor
  receptorUsoCfdi          String    // Clave SAT c_UsoCFDI

  // Totales (precision monetaria MXN)
  subtotal                    Decimal  @db.Decimal(12, 2)
  descuento                   Decimal  @default(0) @db.Decimal(12, 2)
  totalImpuestosTrasladados   Decimal  @default(0) @db.Decimal(12, 2)
  totalImpuestosRetenidos     Decimal  @default(0) @db.Decimal(12, 2)
  total                       Decimal  @db.Decimal(12, 2)

  // Sello digital del emisor
  noCertificado  String?    // 20 digitos del CSD
  certificado    String?    // Base64 del .cer DER
  sello          String?    // Base64 firma SHA256-RSA de la cadena original
  cadenaOriginal String?    // Cadena original para auditoria

  // Timbre Fiscal Digital (del PAC)
  selloSat          String?
  noCertificadoSat  String?
  fechaTimbrado     DateTime?
  rfcProvCertif     String?
  xmlTimbrado       String?  @db.Text  // XML completo timbrado

  // FASE 49: Portal — pago online
  paidAt                DateTime?
  stripePaymentIntentId String?

  // Relaciones
  items          InvoiceItem[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([tenantId, serie, folio])
  @@index([tenantId, status])
  @@index([tenantId, fechaEmision])
}

/// Concepto (linea) de una factura CFDI 4.0.
/// Ref: Anexo 20 — Nodo: cfdi:Concepto.
model InvoiceItem {
  id              String   @id @default(uuid())
  invoiceId       String
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Datos del concepto
  claveProdServ   String   // Clave SAT c_ClaveProdServ
  noIdentificacion String? // Clave interna del producto/servicio
  cantidad        Decimal  @db.Decimal(10, 6)
  claveUnidad     String   // Clave SAT c_ClaveUnidad (ej. "E48", "H87")
  unidad          String?  // Descripcion de la unidad
  descripcion     String
  valorUnitario   Decimal  @db.Decimal(12, 6)
  importe         Decimal  @db.Decimal(12, 2) // cantidad * valorUnitario redondeado
  descuento       Decimal  @default(0) @db.Decimal(12, 2)
  objetoImp       String   @default("02") // c_ObjetoImp: "02" = Si objeto de impuesto

  // Impuestos trasladados del concepto
  trasladoBase          Decimal?  @db.Decimal(12, 2)
  trasladoImpuesto      String?   // "002" = IVA, "003" = IEPS
  trasladoTipoFactor    String?   // "Tasa", "Cuota", "Exento"
  trasladoTasaOCuota    Decimal?  @db.Decimal(8, 6) // 0.160000
  trasladoImporte       Decimal?  @db.Decimal(12, 2)

  // Impuestos retenidos del concepto (opcional)
  retencionBase         Decimal?  @db.Decimal(12, 2)
  retencionImpuesto     String?   // "001" = ISR, "002" = IVA
  retencionTipoFactor   String?
  retencionTasaOCuota   Decimal?  @db.Decimal(8, 6)
  retencionImporte      Decimal?  @db.Decimal(12, 2)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([invoiceId])
}

// ─── CONTABILIDAD: PARTIDA DOBLE (LEDGER) ──────────────

/// Tipo de cuenta contable (NIF / SAT)
enum AccountType {
  ASSET          // Activo
  LIABILITY      // Pasivo
  EQUITY         // Capital
  REVENUE        // Ingreso
  EXPENSE        // Gasto
  CONTRA_ASSET   // Contra-activo (depreciacion acumulada)
  CONTRA_REVENUE // Contra-ingreso (devoluciones)
}

/// Catalogo de Cuentas Contables por Tenant.
/// Basado en el Codigo Agrupador del SAT (Anexo 24 CFF).
/// Ref: CFF Art. 28 fraccion III, NIF A-1 y NIF A-2.
model Account {
  id            String      @id @default(uuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  code          String      // Codigo contable SAT (ej. "102.01", "401.01", "208.01")
  name          String      // Nombre de la cuenta (ej. "Bancos", "Ventas", "IVA Trasladado")
  accountType   AccountType // Naturaleza de la cuenta
  parentCode    String?     // Codigo de la cuenta padre (para arbol jerarquico)
  level         Int         @default(1) // Nivel en el arbol (1=mayor, 2=sub, 3=detalle)
  isActive      Boolean     @default(true)

  // Saldos acumulados (se actualizan con cada poliza)
  debitBalance  Decimal     @default(0) @db.Decimal(14, 2)  // Total cargos historico
  creditBalance Decimal     @default(0) @db.Decimal(14, 2)  // Total abonos historico

  journalLines  JournalLine[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, accountType])
  @@index([tenantId, parentCode])
}

/// Poliza contable (Journal Entry).
/// Cada poliza tiene N lineas donde sum(cargos) == sum(abonos).
/// Ref: CFF Art. 28, NIF A-2 — Postulado de Dualidad Economica.
model JournalEntry {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  entryNumber   Int      // Consecutivo por tenant
  date          DateTime // Fecha de la operacion
  concept       String   // Descripcion de la poliza
  reference     String?  // Referencia externa (UUID CFDI, num factura, etc.)
  entryType     String   @default("DIARIO") // DIARIO, INGRESO, EGRESO, AJUSTE

  // Origen automatico
  sourceType    String?  // XML_IMPORT, POS_SALE, MANUAL, CFDI_EMITIDO
  sourceId      String?  // ID del documento origen (xmlBatchId, posOrderId, invoiceId)

  // Totales (para validacion rapida)
  totalDebit    Decimal  @db.Decimal(14, 2)
  totalCredit   Decimal  @db.Decimal(14, 2)
  isBalanced    Boolean  @default(true) // sum(cargos) == sum(abonos)

  lines         JournalLine[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, date])
  @@index([tenantId, entryType])
  @@index([tenantId, sourceType])
}

/// Linea de poliza (cargo o abono a una cuenta).
model JournalLine {
  id              String       @id @default(uuid())
  journalEntryId  String
  journalEntry    JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  accountId       String
  account         Account      @relation(fields: [accountId], references: [id])

  description     String?      // Detalle de la linea
  debit           Decimal      @default(0) @db.Decimal(14, 2) // Cargo
  credit          Decimal      @default(0) @db.Decimal(14, 2) // Abono

  createdAt       DateTime     @default(now())

  @@index([journalEntryId])
  @@index([accountId])
}

/// Lote de XMLs importados (para trazabilidad del Drag & Drop).
model XmlBatch {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  fileName        String   // Nombre del archivo ZIP original
  totalFiles      Int      // Total de XMLs en el ZIP
  processed       Int      @default(0) // XMLs procesados exitosamente
  errors          Int      @default(0) // XMLs con error
  status          String   @default("PROCESSING") // PROCESSING, COMPLETED, ERROR

  // Resumen de lo importado
  totalIngresos   Int      @default(0)
  totalEgresos    Int      @default(0)
  totalPagos      Int      @default(0)
  totalNominas    Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, createdAt])
}

// ─── FASE 12: CAPITAL HUMANO ─────────────────────────────

// Empleados del Tenant
model Employee {
  id              String       @id @default(cuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Identificacion legal
  curp            String       // 18 caracteres — CURP unica
  rfc             String?      // RFC personal del empleado (puede diferir del tenant)
  name            String
  email           String?
  phone           String?

  // Identificadores laborales
  employeeNumber  String?      // Número de empleado único por tenant

  // Datos laborales
  position        String       // Puesto / titulo
  department      String?      // Departamento / area (legacy)
  area            String?      // Área o Equipo — indexado para reportes

  // Turno asignado
  shiftId         String?
  shift           WorkShift?   @relation(fields: [shiftId], references: [id])

  // Nomina
  salary          Decimal      @db.Decimal(12, 2)   // Salario mensual o quincenal
  salaryType      String       @default("MENSUAL")  // MENSUAL | QUINCENAL
  imssNumber      String?      // Numero de seguridad social IMSS
  bankAccount     String?      // CLABE interbancaria para pago de nomina

  // Control
  hireDate        DateTime     // Fecha de contratacion
  terminationDate DateTime?    // Fecha de baja (null = activo)
  active          Boolean      @default(true)

  // Relaciones
  attendances     Attendance[]
  payrollItems    PayrollItem[]  // FASE 15
  documents       EmployeeDocument[]
  leaveRequests   LeaveRequest[]
  reviews         PerformanceReview[]
  portalTokens    EmployeePortalToken[] // Portal de autoservicio

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([tenantId, curp])
  @@unique([tenantId, employeeNumber])
  @@index([tenantId])
  @@index([tenantId, active])
  @@index([tenantId, area])
}

// Registro de asistencias diarias
model Attendance {
  id              String     @id @default(cuid())
  employeeId      String
  employee        Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date            DateTime   @db.Date       // Solo la fecha (sin hora)
  clockInTime     DateTime?  // Hora de entrada
  clockOutTime    DateTime?  // Hora de salida

  // Geolocalización de entrada
  checkInLat      Float?     // Latitud al checar entrada
  checkInLon      Float?     // Longitud al checar entrada
  checkInAddress  String?    // Descripción/dirección al checar entrada
  checkInStatus   String?    // "DENTRO" | "FUERA" — vs geocerca de trabajo

  // Geolocalización de salida
  checkOutLat     Float?
  checkOutLon     Float?
  checkOutAddress String?
  checkOutStatus  String?    // "DENTRO" | "FUERA"

  // Anomalías y distancia
  isAnomaly       Boolean    @default(false)
  anomalyReason   String?    // Justificación del empleado si checó fuera de rango
  distanceMeters  Float?     // Distancia calculada (Haversine) al checar entrada

  // Justificantes
  absent          Boolean    @default(false)  // Falta
  justified       Boolean    @default(false)  // Falta justificada
  notes           String?                     // Observaciones

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@index([employeeId, isAnomaly])
}

// ─── FASE 15: NÓMINA ─────────────────────────────────────

// Corrida de nómina (quincena o mes)
model PayrollRun {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  period      String        // Ej: "2026-03-Q1" | "2026-03"
  periodLabel String        // Ej: "Quincena 1 Marzo 2026"
  startDate   DateTime
  endDate     DateTime
  status      String        @default("DRAFT")  // DRAFT | CLOSED

  totalBruto  Decimal       @db.Decimal(14, 2)
  totalISR    Decimal       @db.Decimal(14, 2)
  totalIMSS   Decimal       @db.Decimal(14, 2)
  totalNeto   Decimal       @db.Decimal(14, 2)

  items       PayrollItem[]

  journalEntryId String?    // Póliza contable generada al cerrar

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([tenantId, period])
  @@index([tenantId])
}

// Línea de nómina por empleado en una corrida
model PayrollItem {
  id            String     @id @default(cuid())
  payrollRunId  String
  payrollRun    PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee   @relation(fields: [employeeId], references: [id])

  employeeName  String
  position      String
  bruto         Decimal    @db.Decimal(12, 2)   // Salario bruto del periodo
  isr           Decimal    @db.Decimal(12, 2)   // Retención ISR
  imss          Decimal    @db.Decimal(12, 2)   // Cuota obrera IMSS
  absenceDays   Int        @default(0)           // Días de falta
  absenceDeduct Decimal    @db.Decimal(12, 2) @default(0)  // Deducción por faltas
  neto          Decimal    @db.Decimal(12, 2)   // Neto a pagar

  // FASE 48: CFDI Nómina Digital
  cfdiUuid          String?
  cfdiStatus        String    @default("PENDING") // PENDING | STAMPED | ERROR
  cfdiXml           String?   @db.Text
  cfdiSello         String?   @db.Text
  cfdiNoCertificado String?
  rfcProvCertif     String?
  fechaTimbrado     DateTime?
  cfdiError         String?

  createdAt     DateTime   @default(now())

  @@index([payrollRunId])
  @@index([employeeId])
}

// ─── FASE 16: CAJA CHICA ─────────────────────────────────

// Fondo fijo de caja chica
model PettyCashFund {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name            String            @default("Caja Chica")
  description     String?
  fundAmount      Decimal           @db.Decimal(12, 2)  // Monto del fondo fijo autorizado
  minimumBalance  Decimal?          @db.Decimal(12, 2)  // Umbral para solicitar reposición
  active          Boolean           @default(true)

  // Custodio responsable
  custodianName   String?
  custodianEmail  String?
  custodianUserId String?           // userId del custodio en el sistema

  // Estado de arqueo
  lastAuditAt     DateTime?
  lastAuditBalance Decimal?         @db.Decimal(12, 2)

  expenses    PettyCashExpense[]
  replenishments PettyCashReplenishment[]

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([tenantId])
}

// Movimiento / gasto de caja chica
model PettyCashExpense {
  id            String        @id @default(cuid())
  fundId        String
  fund          PettyCashFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  date          DateTime
  concept       String
  amount        Decimal       @db.Decimal(10, 2)
  category      String        @default("General")  // Papelería, Transporte, Viáticos, etc.
  costCenter    String?       // Centro de costos
  receiptRef    String?       // Folio del comprobante físico

  // CFDI validado
  xmlUrl        String?       // URL en Supabase Storage
  xmlValidated  Boolean       @default(false)
  xmlFolio      String?       // UUID del CFDI
  providerRfc   String?       // RFC del proveedor
  ivaAmount     Decimal?      @db.Decimal(10, 2)

  // Estado
  status        String        @default("PENDIENTE") // PENDIENTE | APROBADO | RECHAZADO

  createdAt     DateTime      @default(now())

  @@index([fundId])
  @@index([fundId, date])
  @@index([fundId, status])
}

// Reposición del fondo de caja chica
model PettyCashReplenishment {
  id          String        @id @default(cuid())
  fundId      String
  fund        PettyCashFund @relation(fields: [fundId], references: [id], onDelete: Cascade)

  amount      Decimal       @db.Decimal(12, 2)
  requestedAt DateTime      @default(now())
  approvedAt  DateTime?
  approvedBy  String?       // userId
  notes       String?
  status      String        @default("SOLICITADA") // SOLICITADA | APROBADA | EJECUTADA

  @@index([fundId])
}

// ─── FASE 17: SCM INVENTARIOS ────────────────────────────────────────────────

/// Almacén físico o virtual del tenant.
model Warehouse {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String                            // "Almacén Central", "Tienda", "Consigna"
  code        String                            // Código corto: "ALM-01"
  address     String?
  isDefault   Boolean          @default(false)  // Almacén principal del tenant
  isLocked    Boolean          @default(false)  // Bloqueado durante inventario físico
  active      Boolean          @default(true)

  movements   StockMovement[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

/// Movimiento de inventario: entrada, salida, ajuste o transferencia.
model StockMovement {
  id           String            @id @default(cuid())
  tenantId     String            // Desnormalizado para queries rápidas
  warehouseId  String
  warehouse    Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  productId    String
  product      Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  type         StockMovementType
  quantity     Int               // Positivo = entrada, negativo = salida/ajuste
  quantityBefore Int             // Stock antes del movimiento
  quantityAfter  Int             // Stock después del movimiento

  reference    String?           // Folio POS, UUID factura, OC, etc.
  notes        String?

  createdAt    DateTime          @default(now())

  @@index([tenantId, productId])
  @@index([warehouseId, createdAt])
  @@index([productId, createdAt])
}

enum StockMovementType {
  ENTRADA      // Compra / recepción
  SALIDA       // Venta POS / despacho
  AJUSTE_POS   // Ajuste positivo al alza
  AJUSTE_NEG   // Ajuste negativo a la baja
  TRANSFERENCIA // Movimiento entre almacenes
  DEVOLUCION   // Devolución de cliente
}

// ─── FASE 18: CRM PIPELINE ───────────────────────────────────────────────────

/// Columna/etapa del pipeline de ventas.
/// Se crean 5 columnas por defecto al primer uso.
model PipelineColumn {
  id       String  @id @default(cuid())
  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name     String               // "Prospecto", "Calificado", "Propuesta"…
  position Int                  // Orden de izquierda a derecha
  color    String @default("#6366f1")
  isWon    Boolean @default(false)  // Columna "Ganado"
  isLost   Boolean @default(false)  // Columna "Perdido"

  deals    Deal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, position])
}

/// Oportunidad / Deal del pipeline CRM.
model Deal {
  id         String         @id @default(cuid())
  tenantId   String
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  columnId   String
  column     PipelineColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)

  title       String               // Nombre de la oportunidad
  value       Decimal @db.Decimal(12, 2) @default(0) // Valor estimado
  probability Int     @default(50)  // % de cierre

  contactName  String?
  contactEmail String?
  contactPhone String?
  notes        String?

  expectedCloseDate DateTime?
  wonAt             DateTime?  // Fecha real de cierre (ganado)
  lostAt            DateTime?  // Fecha de cierre (perdido)

  position   Int     @default(0)    // Orden dentro de la columna

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, columnId])
  @@index([tenantId, createdAt])
}

// ─── FASE 25: RBAC — Audit Log ────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String

  // Actor (null = system/webhook)
  actorId     String?
  actorName   String?
  actorEmail  String?

  // Qué pasó
  action      String   // ROLE_CHANGE | ACCESS_DENIED | USER_INVITED | USER_REMOVED | LOGIN | etc.
  resource    String   // User | Invoice | Employee | Route | etc.
  resourceId  String?  // ID del recurso afectado

  // Datos del cambio (antes/después)
  oldData     Json?
  newData     Json?

  // Metadatos de la solicitud
  ip          String?
  userAgent   String?
  severity    String   @default("info") // info | warning | critical

  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@index([tenantId, severity])
}

model Notification {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?  // null = para todos los usuarios del tenant

  type      String   // INVOICE_DUE | INVOICE_STAMPED | PAYMENT_RECEIVED | LOW_STOCK | DEAL_WON | PAYROLL_READY | ACCESS_DENIED
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?  // ruta de navegación al hacer click

  createdAt DateTime @default(now())

  @@index([tenantId, userId, read])
  @@index([tenantId, createdAt])
}

model CustomerPortalToken {
  id           String    @id @default(cuid())
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  token        String    @unique @default(cuid())
  expiresAt    DateTime
  lastAccessAt DateTime?
  createdAt    DateTime  @default(now())

  @@index([token])
  @@index([customerId])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  title       String
  description String?
  start       DateTime
  end         DateTime
  allDay      Boolean  @default(false)
  type        String   @default("MANUAL")
  // MANUAL | INVOICE_DUE | PAYROLL_DATE | DEAL_FOLLOWUP | DELIVERY
  color       String?
  relatedId   String?
  relatedType String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, start])
  @@index([tenantId, type])
}

// ─── FASE 31: SCM Compras + Logística ────────────────────────────────────────

model Supplier {
  id           String          @id @default(cuid())
  tenantId     String
  name         String
  rfc          String?
  email        String?
  phone        String?
  address      String?
  contactName  String?
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  tenantId    String
  supplierId  String?
  supplier    Supplier?           @relation(fields: [supplierId], references: [id])
  orderNumber Int
  status      String              @default("DRAFT")
  // DRAFT | SENT | PARTIAL | RECEIVED | CANCELLED
  notes       String?
  total       Decimal             @default(0) @db.Decimal(14,2)
  expectedAt  DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  items       PurchaseOrderItem[]
  shipments   Shipment[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId, status])
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId        String?
  productName      String
  quantity         Decimal       @db.Decimal(14,4)
  quantityReceived Decimal       @default(0) @db.Decimal(14,4)
  unitCost         Decimal       @db.Decimal(14,4)
  subtotal         Decimal       @db.Decimal(14,2)

  @@index([purchaseOrderId])
}

model Shipment {
  id              String        @id @default(cuid())
  tenantId        String
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  trackingNumber  String?
  carrier         String?
  status          String        @default("PENDING")
  // PENDING | IN_TRANSIT | DELIVERED | RETURNED
  origin          String?
  destination     String?
  estimatedAt     DateTime?
  deliveredAt     DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId, status])
  @@index([purchaseOrderId])
}

// ─── FASE 32: CRM Marketing + Soporte ────────────────────────────────────────

model Campaign {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  subject     String
  htmlBody    String   @db.Text
  status      String   @default("DRAFT")
  // DRAFT | SCHEDULED | SENT | CANCELLED
  sentAt      DateTime?
  recipientCount Int   @default(0)
  openCount   Int      @default(0)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
}

model SupportTicket {
  id          String           @id @default(cuid())
  tenantId    String
  customerId  String?
  customer    Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  title       String
  description String?
  status      String           @default("OPEN")
  // OPEN | IN_PROGRESS | WAITING | RESOLVED | CLOSED
  priority    String           @default("MEDIUM")
  // LOW | MEDIUM | HIGH | URGENT
  assigneeId  String?
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  messages    SupportMessage[]

  @@index([tenantId, status])
  @@index([tenantId, priority])
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String?
  authorName String
  body      String        @db.Text
  isInternal Boolean      @default(false)
  createdAt DateTime      @default(now())

  @@index([ticketId])
}

// ─── FASE 33: MRP Real ────────────────────────────────────────────────────────

model BOM {
  id        String    @id @default(cuid())
  tenantId  String
  productId String
  product   Product   @relation(fields: [productId], references: [id])
  version   String    @default("1.0")
  notes     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  items             BOMItem[]
  productionOrders  ProductionOrder[]

  @@unique([tenantId, productId, version])
  @@index([tenantId])
}

model BOMItem {
  id          String  @id @default(cuid())
  bomId       String
  bom         BOM     @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentId String
  component   Product @relation("BOMComponent", fields: [componentId], references: [id])
  quantity    Decimal @db.Decimal(14,4)
  unit        String  @default("pza")

  @@index([bomId])
}

model ProductionOrder {
  id          String              @id @default(cuid())
  tenantId    String
  bomId       String
  bom         BOM                 @relation(fields: [bomId], references: [id])
  quantity    Decimal             @db.Decimal(14,4)
  status      String              @default("PLANNED")
  // PLANNED | IN_PROGRESS | COMPLETED | CANCELLED
  startDate   DateTime?
  endDate     DateTime?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  inspections QualityInspection[]

  @@index([tenantId, status])
}

model QualityInspection {
  id                String          @id @default(cuid())
  productionOrderId String
  productionOrder   ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  result            String          @default("PENDING")
  // PENDING | PASS | FAIL | CONDITIONAL
  notes             String?
  inspectedAt       DateTime?
  createdAt         DateTime        @default(now())

  @@index([productionOrderId])
}

// ─── FASE 34: RRHH Documentos + Vacaciones + Desempeño ────────────────────────

model EmployeeDocument {
  id           String    @id @default(cuid())
  tenantId     String
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type         String    // CONTRATO | NDA | CONSTANCIA | ALTA_IMSS | BAJA_IMSS | OTRO
  name         String    // Nombre descriptivo del documento
  fileUrl      String    // URL pública o path en storage
  fileSize     Int?      // Bytes
  mimeType     String?

  expiresAt    DateTime? // Para documentos con vigencia
  notes        String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([employeeId])
}

model LeaveRequest {
  id           String    @id @default(cuid())
  tenantId     String
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type         String    // VACACIONES | PERMISO | INCAPACIDAD | DUELO
  startDate    DateTime  @db.Date
  endDate      DateTime  @db.Date
  days         Int       // Días calendario
  reason       String?
  status       String    @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedById String?   // userId que aprobó
  approvedAt   DateTime?
  rejectedReason String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([employeeId])
  @@index([tenantId, status])
}

model PerformanceReview {
  id           String    @id @default(cuid())
  tenantId     String
  employeeId   String
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  period       String    // e.g. "2026-Q1"
  score        Int       // 1-5
  goals        String?   // Objetivos del período (texto libre / JSON)
  achievements String?   // Logros
  improvements String?   // Áreas de mejora
  reviewerName String?   // Nombre del evaluador
  status       String    @default("DRAFT") // DRAFT | PUBLISHED

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([employeeId, period])
  @@index([tenantId])
  @@index([employeeId])
}

// ─── FASE 37: Integraciones Externas ──────────────────────────────────────────

model WebhookEndpoint {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  url         String    // Endpoint URL del cliente
  secret      String    // HMAC secret para firma de payloads
  events      String[]  // Array de eventos suscritos: invoice.created, pos.sale, etc.
  active      Boolean   @default(true)
  description String?

  deliveries  WebhookDelivery[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, active])
}

model WebhookDelivery {
  id           String          @id @default(cuid())
  webhookId    String
  webhook      WebhookEndpoint @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  event        String          // Tipo de evento
  payload      Json            // Payload enviado
  statusCode   Int?            // HTTP status de la respuesta
  responseBody String?         // Primeros 500 chars de la respuesta
  success      Boolean         @default(false)
  attemptCount Int             @default(1)
  deliveredAt  DateTime?

  createdAt    DateTime        @default(now())

  @@index([webhookId])
  @@index([webhookId, success])
}

model ApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String    // Label descriptivo
  keyHash     String    @unique  // SHA-256 del API key (nunca almacenar en texto claro)
  keyPrefix   String    // Primeros 8 chars para identificación: "cifra_sk_"
  scopes      String[]  // read:invoices, write:customers, read:inventory, etc.
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  active      Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([keyHash])
}

// ─── FASE 40: Enterprise Multi-empresa ────────────────────────────────────────

model Organization {
  id            String    @id @default(cuid())
  name          String    // Nombre del grupo empresarial
  slug          String    @unique  // URL-friendly identifier
  logoUrl       String?
  ownerId       String    // userId del admin principal
  plan          String    @default("ENTERPRISE") // ENTERPRISE | HOLDING

  members       OrgMember[]
  tenants       OrgTenant[]  // Empresas/subsidiarias vinculadas

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([ownerId])
}

model OrgMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  role           String       @default("VIEWER") // OWNER | ADMIN | VIEWER

  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model OrgTenant {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenantId       String       // FK to Tenant
  alias          String?      // Nombre corto/alias dentro del grupo
  order          Int          @default(0) // Display order

  createdAt      DateTime     @default(now())

  @@unique([organizationId, tenantId])
  @@index([organizationId])
}

// ─── FASE 52: NUEVOS MÓDULOS ──────────────────────────────────────────────────

// Turnos de trabajo para el Reloj Checador
model WorkShift {
  id                  String     @id @default(cuid())
  tenantId            String
  tenant              Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name                String     // "Turno Matutino", "Turno Vespertino", "Turno Nocturno"
  startTime           String     // Hora inicio HH:mm (ej. "08:00")
  endTime             String     // Hora fin HH:mm (ej. "17:00")
  gracePeriodMinutes  Int        @default(15)  // Tolerancia en minutos
  active              Boolean    @default(true)

  employees           Employee[]

  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([tenantId])
}

// Corte de Caja POS — registro inmutable
model CashCut {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  cashierId       String?  // userId del cajero
  supervisorId    String?  // userId del supervisor (si hubo anomalía)
  cutDate         DateTime @default(now())

  // Desglose denominacional (resultado del arqueo ciego)
  // { "1000": 5, "500": 10, "200": 2, "100": 8, "50": 4, "20": 6, "20c": 3, "10c": 10, "5c": 8, "2c": 5, "1c": 20, "50cents": 0 }
  denominations   Json?

  // Totales
  declaredAmount  Decimal  @db.Decimal(12, 2)  // Efectivo contado físicamente
  systemAmount    Decimal  @db.Decimal(12, 2)  // Lo que dice el sistema (ventas efectivo)
  variation       Decimal  @db.Decimal(12, 2)  // declaredAmount - systemAmount

  // Resumen por método de pago
  byPaymentMethod Json?    // { "01": { count: 10, total: 5000 }, ... }
  ordersCount     Int      @default(0)
  grandTotal      Decimal  @db.Decimal(12, 2) @default(0)

  // Estado
  status          String   @default("ABIERTO") // ABIERTO | CERRADO | ANOMALIA_PENDIENTE
  anomalyApproved Boolean  @default(false)
  anomalyNotes    String?  // Notas del supervisor al aprobar anomalía

  // PDF resguardado
  pdfUrl          String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, cutDate])
  @@index([tenantId, status])
}

// ─── TESORERÍA ────────────────────────────────────────────────────────────────

// Cuenta bancaria del tenant
model BankAccount {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  bankName        String                     // "BBVA", "Santander", "Citibanamex"
  alias           String                     // "Cuenta Principal", "Nómina"
  accountNumber   String                     // Últimos 4 dígitos o referencia
  clabe           String?                    // 18 dígitos CLABE interbancaria
  currency        String   @default("MXN")
  accountType     String   @default("CHEQUES") // CHEQUES | AHORRO | INVERSION | NOMINA
  currentBalance  Decimal  @db.Decimal(14, 2) @default(0)
  isActive        Boolean  @default(true)
  notes           String?

  transactions    TreasuryTransaction[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, isActive])
}

// Movimiento bancario / transacción de tesorería
model TreasuryTransaction {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccountId   String
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  date            DateTime
  concept         String
  type            String      // INGRESO | EGRESO | TRANSFERENCIA | INVERSION
  amount          Decimal     @db.Decimal(14, 2)  // Siempre positivo
  balance         Decimal     @db.Decimal(14, 2)  // Saldo después de la operación
  reference       String?     // Número de referencia bancaria
  category        String?     // NOMINA | PROVEEDOR | IMPUESTO | VENTA | INVERSION | OTRO
  notes           String?

  // Conciliación bancaria
  isReconciled    Boolean     @default(false)
  reconciledAt    DateTime?
  invoiceId       String?     // UUID de factura relacionada

  createdAt       DateTime    @default(now())

  @@index([tenantId, date])
  @@index([bankAccountId, date])
  @@index([tenantId, type])
  @@index([tenantId, isReconciled])
}

// ─── MIS CFDI RECIBIDOS ───────────────────────────────────────────────────────

// CFDI recibido del SAT (complementa Invoice que son los emitidos)
model CfdiRecibido {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Identificadores SAT
  uuid            String   @unique  // UUID del timbre
  emisorRfc       String
  emisorNombre    String?
  receptorRfc     String
  serie           String?
  folio           String?

  // Importes
  total           Decimal  @db.Decimal(12, 2)
  subtotal        Decimal? @db.Decimal(12, 2)
  descuento       Decimal? @db.Decimal(12, 2) @default(0)
  totalIva        Decimal? @db.Decimal(12, 2)
  totalIsr        Decimal? @db.Decimal(12, 2)

  // Tipo y fecha
  fechaEmision    DateTime
  fechaTimbrado   DateTime?
  tipoComprobante String   // I | E | T | P | N
  metodoPago      String?
  formaPago       String?
  moneda          String   @default("MXN")

  // Estado SAT
  status          String   @default("VIGENTE") // VIGENTE | CANCELADO
  canceledAt      DateTime?

  // Almacenamiento
  xmlUrl          String?  // URL en Supabase Storage
  xmlContent      String?  @db.Text  // XML completo (opcional, para búsqueda)

  // Validación fiscal
  isEfos          Boolean  @default(false)  // Proveedor en lista negra SAT 69-B
  validated       Boolean  @default(false)
  validatedAt     DateTime?

  // Mapeo contable (motor de reglas)
  accountingMapped Boolean @default(false)
  costCenter       String?
  accountCode      String?  // Cuenta del plan contable
  journalEntryId   String?  // Póliza generada

  // Sincronización
  syncedAt         DateTime @default(now())

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([tenantId, fechaEmision])
  @@index([tenantId, emisorRfc])
  @@index([tenantId, status])
  @@index([tenantId, tipoComprobante])
  @@index([tenantId, accountingMapped])
}

// ─── CONTRATO DIGITAL ────────────────────────────────────────────────────────

/// Datos legales y firma digital recopilados al contratar el servicio.
/// Se generan al finalizar el periodo de prueba y antes del primer pago.
model ContractSignature {
  id                   String     @id @default(uuid())
  tenantId             String     @unique
  tenant               Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  personType           PersonType

  // ── Persona Física ────────────────────────────────────
  fullName             String?    // Nombre completo
  curp                 String?    // CURP (18 caracteres)
  domicilioFiscal      String?    // Domicilio fiscal completo
  rfcFisica            String?    // RFC 13 posiciones
  emailFisica          String?
  phoneFisica          String?

  // ── Persona Moral — Datos de la Empresa ──────────────
  razonSocial          String?    // Denominación social exacta
  rfcEmpresa           String?    // RFC 12 posiciones
  domicilioLegal       String?    // Domicilio legal/fiscal completo
  nacionalidad         String?    @default("Mexicana")

  // ── Persona Moral — Representante Legal ──────────────
  nombreRepresentante  String?
  rfcRepresentante     String?
  emailRepresentante   String?
  celularRepresentante String?

  // ── Acreditación de Personalidad Jurídica ────────────
  numEscritura         String?    // Número de escritura pública
  fechaEscritura       DateTime?  // Fecha de la escritura
  nombreNotario        String?    // Nombre del Notario / Corredor Público
  numNotaria           String?    // Número de Notaría / Correduría
  ciudadNotaria        String?    // Ciudad y estado de la Notaría
  folioMercantil       String?    // Folio Mercantil Electrónico (RPC)
  fechaInscripcionRPC  DateTime?  // Fecha de inscripción en el RPC

  // ── Firma Digital ─────────────────────────────────────
  signatureType        String?    // 'DRAW' | 'EFIRMA'
  signatureData        String?    @db.Text  // Base64 PNG del trazo en canvas
  efirmaFileName       String?    // Nombre del archivo .cer de e.firma SAT
  signedAt             DateTime?

  status               String     @default("PENDING")  // PENDING | SIGNED
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  @@index([status])
}

// ─── MARKETING AUTOMATION ─────────────────────────────────────────────────────

/// Integración OAuth con plataformas de publicidad digital.
/// Los tokens se guardan cifrados a nivel de aplicación.
model MarketingIntegration {
  id           String   @id @default(uuid())
  platform     String   // 'GOOGLE_ADS' | 'META_ADS'
  accessToken  String   // Cifrado en capa de aplicación (AES-256-GCM)
  refreshToken String?
  accountId    String   // ID de la cuenta publicitaria
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([platform, isActive])
}

/// Log diario de métricas de campañas publicitarias.
/// Agrega datos de Google Ads y Meta Ads para el dashboard de RoAS.
model AdCampaignLog {
  id          String   @id @default(uuid())
  platform    String   // 'GOOGLE_ADS' | 'META_ADS'
  campaignId  String   // ID de campaña en la plataforma
  campaignName String? // Nombre descriptivo
  spend       Float    // Gasto del día (MXN)
  impressions Int
  clicks      Int
  conversions Int      // Registros atribuidos
  date        DateTime @default(now())

  @@index([platform, date])
  @@index([date])
}

/// Creatividades de anuncios generadas por IA, pendientes de aprobación.
/// El flujo: generación automática → revisión humana → lanzamiento en plataforma.
model AiGeneratedCreative {
  id          String   @id @default(uuid())
  platform    String   // 'GOOGLE_ADS' | 'META_ADS' | 'TIKTOK' | 'LINKEDIN'
  angle       String?  // Ángulo de venta usado: 'ahorro', 'fiscal', 'tiempo'
  headline    String   // Título del anuncio (máx. 30 chars para Google)
  description String   // Descripción / cuerpo del anuncio
  imagePrompt String?  // Prompt sugerido para generar imagen con DALL-E/Ideogram
  status      String   @default("PENDING_APPROVAL") // PENDING_APPROVAL | ACTIVE | REJECTED
  performance Float?   // CTR o score asignado después de correr
  rejectedReason String? // Motivo de rechazo (feedback para el LLM)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([platform, status])
}

// ─── OPEN BANKING / CONCILIACIÓN BANCARIA ─────────────────────────────────────

/// Conexión a cuenta bancaria vía Open Banking (BBVA, Santander, Banorte, HSBC, Banamex)
model BankConnection {
  id            String             @id @default(uuid())
  tenantId      String
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  bank          String             // 'BBVA' | 'SANTANDER' | 'BANORTE' | 'HSBC' | 'BANAMEX' | 'OTRO'
  bankAccountId String?            // ID de la cuenta en el Open Banking provider
  clabe         String?            // CLABE interbancaria (últimos 4 dígitos visibles)
  alias         String?            // Alias amigable: "Cuenta Operativa BBVA"
  currency      String             @default("MXN")
  isActive      Boolean            @default(true)

  // OAuth tokens del proveedor Open Banking (Belvo / Fintoc / STP)
  accessToken   String?            @db.Text
  refreshToken  String?            @db.Text
  tokenExpiresAt DateTime?
  lastSyncAt    DateTime?
  syncStatus    String             @default("PENDING") // PENDING | OK | ERROR

  transactions  BankTransaction[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([tenantId, isActive])
}

/// Movimiento bancario descargado automáticamente (STP/Open Banking)
model BankTransaction {
  id              String          @id @default(uuid())
  tenantId        String          // Desnormalizado para queries rápidas
  connectionId    String
  connection      BankConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  date            DateTime
  description     String          // Concepto del movimiento
  amount          Decimal         @db.Decimal(14, 2)  // + ingreso, - egreso
  balance         Decimal?        @db.Decimal(14, 2)  // Saldo después del movimiento
  reference       String?         // Clave de rastreo SPEI
  counterpartRfc  String?         // RFC del emisor/receptor
  counterpartName String?         // Nombre del emisor/receptor
  type            String          // 'CREDIT' | 'DEBIT'

  // Conciliación con CFDI
  status          String          @default("UNMATCHED") // UNMATCHED | MATCHED | IGNORED | MANUAL
  matchedCfdiId   String?         // UUID del CFDI conciliado
  matchConfidence Float?          // Porcentaje de confianza del match IA (0–1)
  matchedAt       DateTime?
  matchedBy       String?         // 'AUTO' | userId del usuario que concilió manualmente

  createdAt       DateTime        @default(now())

  @@index([tenantId, date])
  @@index([tenantId, status])
  @@index([connectionId, date])
}

// ─── SAT TOOLS: BUZÓN TRIBUTARIO + 69-B + DIOT ───────────────────────────────

/// Credenciales del SAT para descarga automática de buzón tributario.
/// La FIEL/e.firma se guarda cifrada — NUNCA en texto plano.
model SatCredential {
  id           String   @id @default(uuid())
  tenantId     String   @unique
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rfc          String   // RFC del contribuyente
  cerFileName  String?  // Nombre del archivo .cer de e.firma
  keyFileName  String?  // Nombre del archivo .key de e.firma
  // Los archivos cifrados se guardan en Supabase Storage, nunca en DB
  storageRef   String?  // Path en Supabase Storage: "sat-creds/{tenantId}/"
  isValid      Boolean  @default(false)
  lastValidatedAt DateTime?
  lastDownloadAt  DateTime?
  downloadStatus  String?  // 'OK' | 'ERROR' | 'IN_PROGRESS'
  downloadError   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// XML de CFDI descargado automáticamente del buzón tributario SAT
model SatCfdiDownload {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uuid        String   @unique  // UUID del CFDI (folio fiscal)
  rfcEmisor   String
  rfcReceptor String
  tipo        String   // 'I' | 'E' | 'T' | 'P' | 'N'
  subtotal    Decimal  @db.Decimal(14, 2)
  total       Decimal  @db.Decimal(14, 2)
  fechaTimbrado DateTime
  xmlContent  String?  @db.Text  // XML completo (si se descargó)
  storageRef  String?  // Path en Storage (si se subió ahí)
  direction   String   // 'EMITIDO' | 'RECIBIDO'
  status      String   @default("PENDING") // PENDING | PROCESSED | ERROR
  createdAt   DateTime @default(now())

  @@index([tenantId, tipo])
  @@index([tenantId, direction])
  @@index([tenantId, fechaTimbrado])
  @@index([rfcEmisor])
  @@index([rfcReceptor])
}

/// Validación 69-B del SAT: caché de consultas de RFC contra listas EDOS/EFOS
model Rfc69bValidation {
  id          String   @id @default(uuid())
  rfc         String   @unique  // RFC consultado (sin espacios, mayúsculas)
  razonSocial String?
  status      String   // 'CLEAN' | 'EDOS' | 'EFOS' | 'DEFINITIVE' | 'DESVIRTUADO' | 'ERROR'
  satMessage  String?  @db.Text  // Mensaje completo del SAT
  checkedAt   DateTime @default(now())
  expiresAt   DateTime // Se re-consulta cada 24h automáticamente

  @@index([rfc])
  @@index([status])
  @@index([expiresAt])
}

/// Registro DIOT mensual generado automáticamente desde CFDIs
model DiotRecord {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  period      String   // "2026-03" (YYYY-MM)
  rfcProveedor String
  nombreProveedor String?
  tipoProveedor String  @default("04") // Catálogo SAT: 04=Nacional, 05=Extranjero
  tipoOperacion String  @default("85") // Catálogo SAT operación
  montoTotalPagos Decimal @db.Decimal(14, 2)
  ivaAcreditable  Decimal @db.Decimal(14, 2) @default(0)
  ivaRetenido     Decimal @db.Decimal(14, 2) @default(0)
  ivaNoAcreditable Decimal @db.Decimal(14, 2) @default(0)
  ivaImportacion  Decimal @db.Decimal(14, 2) @default(0)

  status      String   @default("DRAFT") // DRAFT | READY | SUBMITTED
  reportUrl   String?  // URL del TXT generado para subir al SAT
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, period, rfcProveedor])
  @@index([tenantId, period])
}

// ─── ALERTAS DE CUMPLIMIENTO FISCAL ──────────────────────────────────────────

/// Alerta automática de obligación fiscal próxima a vencer
model ComplianceAlert {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type        String   // 'ISR_MENSUAL' | 'IVA_MENSUAL' | 'IMSS_BIMESTRAL' | 'DIOT' | 'DECLARACION_ANUAL' | 'INFONAVIT' | 'REPSE' | 'NOM035'
  title       String
  description String?
  dueDate     DateTime
  daysAhead   Int      // Días de anticipación con que se generó la alerta
  status      String   @default("PENDING") // PENDING | SENT | DISMISSED | OVERDUE
  channel     String   @default("EMAIL")   // 'EMAIL' | 'WHATSAPP' | 'IN_APP'
  sentAt      DateTime?
  dismissedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([tenantId, dueDate])
  @@index([tenantId, status])
}

// ─── REPSE Y SUBCONTRATACIÓN ──────────────────────────────────────────────────

/// Registro en el REPSE (Registro de Prestadoras de Servicios Especializados u Obras)
model RepseRegistration {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  numRepse        String?  // Número de registro REPSE otorgado por STPS
  fechaRegistro   DateTime?
  fechaVencimiento DateTime? // Se renueva cada 3 años
  actividades     String?  @db.Text  // Descripción de servicios especializados
  status          String   @default("PENDING") // PENDING | ACTIVE | EXPIRED | CANCELLED
  certificateUrl  String?  // URL del certificado digital STPS
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

/// Contrato de subcontratación REPSE con cliente/comitente
model RepseContract {
  id              String   @id @default(uuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clienteRfc      String   // RFC del comitente (quien recibe el servicio)
  clienteNombre   String
  objetoContrato  String   @db.Text
  fechaInicio     DateTime
  fechaFin        DateTime?
  montoMensual    Decimal? @db.Decimal(14, 2)
  numTrabajadores Int      @default(0)
  status          String   @default("ACTIVE") // ACTIVE | COMPLETED | CANCELLED
  icsoeReports    RepseIcsoeReport[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
}

/// Reporte ICSOE mensual (Informe de Contratos de Servicios u Obras Especializadas)
model RepseIcsoeReport {
  id              String       @id @default(uuid())
  contractId      String
  contract        RepseContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  period          String       // "2026-03"
  numTrabajadores Int
  totalNomina     Decimal      @db.Decimal(14, 2)
  totalImss       Decimal      @db.Decimal(14, 2)
  totalInfonavit  Decimal      @db.Decimal(14, 2)
  reportUrl       String?      // URL del archivo XML/PDF generado
  status          String       @default("DRAFT") // DRAFT | SUBMITTED
  submittedAt     DateTime?
  createdAt       DateTime     @default(now())

  @@unique([contractId, period])
  @@index([contractId])
}

// ─── NOM-035 RIESGOS PSICOSOCIALES ───────────────────────────────────────────

/// Encuesta NOM-035 aplicada a los empleados de un tenant
model Nom035Survey {
  id          String            @id @default(uuid())
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String            @default("Encuesta NOM-035 STPS-2018")
  period      String            // "2026-Q1" (anual o por periodo)
  guia        String            @default("GUIA_II") // 'GUIA_I' (1-15 empleados) | 'GUIA_II' (>15)
  status      String            @default("DRAFT") // DRAFT | ACTIVE | CLOSED | ARCHIVED
  openAt      DateTime?
  closeAt     DateTime?
  responses   Nom035Response[]
  diagnosticUrl String?         // URL del reporte PDF de diagnóstico
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([tenantId, status])
}

/// Respuesta de un empleado a la encuesta NOM-035
model Nom035Response {
  id          String       @id @default(uuid())
  surveyId    String
  survey      Nom035Survey @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  employeeId  String?      // null si el empleado respondió anónimamente
  token       String       @unique  // Token de acceso único por empleado
  completedAt DateTime?
  // Respuestas codificadas como JSON (pregunta_id → valor 0-4)
  answers     String?      @db.Text // JSON: {"p1": 2, "p2": 3, ...}
  // Scores calculados
  scoreTotal  Int?         // 0-100
  riskLevel   String?      // 'NULO' | 'BAJO' | 'MEDIO' | 'ALTO' | 'MUY_ALTO'
  createdAt   DateTime     @default(now())

  @@index([surveyId])
  @@index([token])
}

// ─── FLUJO DE EFECTIVO Y TESORERÍA PREDICTIVA ────────────────────────────────

/// Proyección de flujo de efectivo a 30/60/90 días
model CashFlowProjection {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date         DateTime // Fecha proyectada
  type         String   // 'INGRESO' | 'EGRESO'
  category     String   // 'COBRANZA' | 'NOMINA' | 'PROVEEDOR' | 'IMPUESTO' | 'OTRO'
  description  String
  amount       Decimal  @db.Decimal(14, 2)
  isConfirmed  Boolean  @default(false)  // false=proyección, true=confirmado
  linkedId     String?  // ID del CFDI, PayrollRun, etc. que origina la proyección
  linkedType   String?  // 'INVOICE' | 'PAYROLL' | 'VENDOR_BILL' | 'TAX'
  createdAt    DateTime @default(now())

  @@index([tenantId, date])
  @@index([tenantId, type])
}

// ─── PORTAL DEL EMPLEADO ──────────────────────────────────────────────────────

/// Token de acceso temporal al portal de autoservicio del empleado
model EmployeePortalToken {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  token       String   @unique @default(uuid())
  expiresAt   DateTime
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([employeeId])
  @@index([token])
}


// ─── CARTA PORTE 3.0 ──────────────────────────────────────────────────────────

/// Complemento Carta Porte para traslado de mercancías (NOM-187-SCT2)
model CartaPorte {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceId      String?  // CFDI al que se adjunta (si aplica)

  // Datos del traslado
  transpInternac String   @default("No")  // 'Si' | 'No'
  entradaSalida  String?  // 'Entrada' | 'Salida' (si es internacional)
  viaTransporte  String   @default("01") // 01=Autotransporte, 03=Aéreo, 04=Marítimo
  totalDistRec   Decimal  @db.Decimal(10, 2) // Distancia total recorrida (km)

  // Origen y destino
  origenCp       String   // Código postal origen
  origenDomicilio String?
  destinoCp      String   // Código postal destino
  destinoDomicilio String?
  fechaSalidaLlegada DateTime

  // Vehículo / transportista
  rfcTransportista String?
  numPlacas      String?
  anioModelo     String?
  configVehicular String?  // Clave catálogo SCT: C2, C3, T3S2, etc.
  numPermitoSCT  String?   // Permiso SCT del transportista

  // Operador
  rfcOperador    String?
  nombreOperador String?
  numLicencia    String?

  // Mercancías (JSON array de claves SAT, descripciones, pesos)
  mercancias     String   @db.Text  // JSON: [{clave, descripcion, cantidad, pesoKg, valorMercancia}]

  status         String   @default("DRAFT") // DRAFT | STAMPED | CANCELLED
  cfdiUuid       String?  // UUID del CFDI con Carta Porte sellado
  xmlContent     String?  @db.Text

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, fechaSalidaLlegada])
}
